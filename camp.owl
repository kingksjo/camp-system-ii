<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://www.semanticweb.org/dell/ontologies/2025/11/MyCampSystem"
         xmlns="http://www.semanticweb.org/dell/ontologies/2025/11/MyCampSystem#"
         xmlns:swrl="http://www.w3.org/2003/11/swrl#">

<owl:Ontology rdf:about="http://www.semanticweb.org/dell/ontologies/2025/11/MyCampSystem">
  <rdfs:comment xml:lang="en">this ontology is for an aircraft mainatenance programme 
</rdfs:comment>
</owl:Ontology>

<owl:ObjectProperty rdf:about="#affectsComponents">
  <rdfs:domain rdf:resource="#Fault"/>
  <rdfs:range rdf:resource="#SensorData"/>
  <rdfs:range rdf:resource="#AircraftComponent"/>
  <rdfs:comment xml:lang="en">Links a fault to the aircraft component it impacts</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#authorizedBy">
  <rdfs:domain rdf:resource="#MaintenanceProcess"/>
  <rdfs:range rdf:resource="#RegulatoryRequirement"/>
  <rdfs:range rdf:resource="#MaintenancePersonnel"/>
  <rdfs:comment xml:lang="en">Indicates that a maintenance activity is authorized by a regulatory requirement or document</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#compliesWith">
  <rdfs:domain rdf:resource="#MaintenanceProcess"/>
  <rdfs:range rdf:resource="#RegulatoryRequirement"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relates an aircraft, maintenance process, or component to a regulatory requirement or directive that it satisfies.

</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#detectedBy">
  <rdfs:domain rdf:resource="#Fault"/>
  <rdfs:range rdf:resource="#SensorData"/>
  <rdfs:comment xml:lang="en">Indicates the sensor data type used to detect or identify a fault.</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#documentsRequirement">
  <rdfs:domain rdf:resource="#MaintenanceProcess"/>
  <rdfs:range rdf:resource="#RegulatoryRequirement"/>
  <rdfs:domain rdf:resource="#RegulatoryRequirement"/>
  <rdfs:range rdf:resource="#MantenanceDocument"/>
  <rdfs:comment xml:lang="en">Links a maintenance document to the regulatory requirement it supports or explain</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#followsProcedure">
  <rdfs:range rdf:resource="#MaintenanceProcedure"/>
  <rdfs:domain rdf:resource="#MaintenanceProcess"/>
  <rdfs:domain rdf:resource="#MaintenanceTask"/>
  <rdfs:comment xml:lang="en">Indicates that a maintenance process is carried out according to a defined maintenance document or procedure.</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#generatedBy">
  <rdfs:range rdf:resource="#Aircraft"/>
  <rdfs:range rdf:resource="#AircraftComponent"/>
  <rdfs:domain rdf:resource="#SensorData"/>
  <rdfs:comment xml:lang="en">Links sensor data to the aircraft or component that produced it</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasComponent">
  <rdfs:domain rdf:resource="#Aircraft"/>
  <rdfs:range rdf:resource="#AircraftComponent"/>
  <rdfs:comment xml:lang="en">Associates an aircraft with one or more aircraft components that are installed on it</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasFault">
  <rdfs:domain rdf:resource="#AircraftComponent"/>
  <rdfs:range rdf:resource="#Fault"/>
  <rdfs:comment xml:lang="en">Links an aircraft or aircraft component to a fault that affects it</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasOperationalMetric">
  <rdfs:domain rdf:resource="#FlightOperation"/>
  <rdfs:range rdf:resource="#OperationalMetric"/>
  <rdfs:domain rdf:resource="#Aircraft"/>
  <rdfs:comment xml:lang="en">Associates a flight operation with recorded operational metrics</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasRegulatoryRequirement">
  <rdfs:domain rdf:resource="#MaintenanceProcess"/>
  <rdfs:range rdf:resource="#RegulatoryRequirement"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relates an aircraft, maintenance process, or component to a regulatory requirement or directive that it satisfies.

</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasSensorData">
  <rdfs:domain rdf:resource="#AircraftComponent"/>
  <rdfs:range rdf:resource="#SensorData"/>
  <rdfs:comment xml:lang="en">Connects an aircraft or aircraft component to sensor data generated during operation or monitoring</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#performedBy">
  <rdfs:range rdf:resource="#MaintenancePersonnel"/>
  <rdfs:domain rdf:resource="#MaintenanceProcess"/>
  <rdfs:comment xml:lang="en">Indicates the maintenance personnel responsible for performing a maintenance process or task</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#performedOn">
  <rdfs:domain rdf:resource="#MaintenanceProcess"/>
  <rdfs:range rdf:resource="#Part"/>
  <rdfs:range rdf:resource="#AircraftComponent"/>
  <rdfs:comment xml:lang="en">Identifies the aircraft or aircraft component on which a maintenance process is performed</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#replacsPart">
  <rdfs:domain rdf:resource="#MaintenanceProcess"/>
  <rdfs:range rdf:resource="#Part"/>
  <rdfs:domain rdf:resource="#MaintenanceTask"/>
  <rdfs:comment xml:lang="en">Indicates that a maintenance process replaces an existing part with another</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#requiresPart">
  <rdfs:domain rdf:resource="#MaintenanceProcess"/>
  <rdfs:range rdf:resource="#Part"/>
  <rdfs:domain rdf:resource="#MaintenanceTask"/>
  <rdfs:comment xml:lang="en">Specifies the aircraft part required to complete a maintenance process or task</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#requiresTask">
  <rdfs:domain rdf:resource="#MaintenancePlan"/>
  <rdfs:range rdf:resource="#MaintenanceSchedule"/>
  <rdfs:domain rdf:resource="#MaintenanceProcess"/>
  <rdfs:range rdf:resource="#MaintenanceTask"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#requiresTools">
  <rdfs:domain rdf:resource="#MaintenanceProcess"/>
  <rdfs:range rdf:resource="#MaintenanceTools"/>
  <rdfs:domain rdf:resource="#MaintenanceTask"/>
  <rdfs:comment xml:lang="en">Identifies the tools required to perform a maintenance process or task.</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#resultsIn">
  <rdfs:range rdf:resource="#Fault"/>
  <rdfs:domain rdf:resource="#MaintenanceProcess"/>
  <rdfs:range rdf:resource="#MaintenanceRecord"/>
  <rdfs:comment xml:lang="en">Indicates the outcome of a maintenance process, such as fault resolution or component replacement</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#scheduledAfterFlightCycles">
  <rdfs:range rdf:resource="#FlightCycles"/>
  <rdfs:domain rdf:resource="#MaintenanceProcess"/>
  <rdfs:domain rdf:resource="#MaintenanceSchedule"/>
  <rdfs:comment xml:lang="en">Indicates that a maintenance process is scheduled once a specified number of flight cycles has been reached</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#scheduledAfterFlightHours">
  <rdfs:range rdf:resource="#FlightHours"/>
  <rdfs:domain rdf:resource="#MaintenanceProcess"/>
  <rdfs:domain rdf:resource="#MaintenanceSchedule"/>
  <rdfs:comment xml:lang="en">Indicates that a maintenance process is scheduled once a specified number of flight hours has been reached.</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#scheduledIn">
  <rdfs:range rdf:resource="#FlightOperation"/>
  <rdfs:domain rdf:resource="#MaintenanceProcess"/>
  <rdfs:range rdf:resource="#MaintenanceSchedule"/>
  <rdfs:comment xml:lang="en">Specifies the operational or maintenance time window in which a maintenance process is planned to occur</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#triggersMaintenance">
  <rdfs:domain rdf:resource="#Fault"/>
  <rdfs:range rdf:resource="#MaintenanceActivity"/>
  <rdfs:range rdf:resource="#MaintenanceProcess"/>
  <rdfs:comment xml:lang="en">Indicates that a detected fault or condition initiates a required maintenance process</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#requiresMaintenance"/>

<owl:ObjectProperty rdf:about="#usesTool"/>

<owl:ObjectProperty rdf:about="#followsDocument"/>

<owl:ObjectProperty rdf:about="#monitors"/>

<owl:ObjectProperty rdf:about="#producesIndicator">
  <rdfs:domain rdf:resource="#SensorData"/>
  <rdfs:range rdf:resource="#ConditionIndicator"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#indicatesFault">
  <rdfs:domain rdf:resource="#ConditionIndicator"/>
  <rdfs:range rdf:resource="#Fault"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#resultsInAssessment"/>

<owl:ObjectProperty rdf:about="#hasFlightStatus">
  <rdfs:domain rdf:resource="#Aircraft"/>
  <rdfs:range rdf:resource="#AircraftStatus"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasAMMReference">
  <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:range rdf:resource="#AMM_Chapter"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isPartOf">
  <rdfs:domain rdf:resource="#AircraftComponent"/>
  <rdfs:range rdf:resource="#AircraftComponent"/>
  <owl:inverseOf rdf:resource="#hasPart"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasPart">
  <rdfs:domain rdf:resource="#AircraftComponent"/>
  <rdfs:range rdf:resource="#AircraftComponent"/>
  <owl:inverseOf rdf:resource="#isPartOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#requiresLicense">
  <rdfs:domain rdf:resource="#AircraftComponent"/>
  <rdfs:range rdf:resource="#LicenseType"/>
</owl:ObjectProperty>

<owl:DatatypeProperty rdf:about="#hasDateperformed">
  <rdfs:domain rdf:resource="#MaintenanceRecord"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
  <rdfs:comment xml:lang="en">date of maintenance</rdfs:comment>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#hasDescription">
  <rdfs:domain rdf:resource="#MaintenanceProcedure"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  <rdfs:comment xml:lang="en">procedure text</rdfs:comment>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#hasFlightCycles">
  <rdfs:domain rdf:resource="#Aircraft"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  <rdfs:comment xml:lang="en">total flight cycles the aircraft has undergone
</rdfs:comment>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#hasFlightHours">
  <rdfs:domain rdf:resource="#Aircraft"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">total flight hours</rdfs:comment>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#hasIntervalHours">
  <rdfs:domain rdf:resource="#MaintenanceTask"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">interval between required checks</rdfs:comment>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#hasTechnicianID">
  <rdfs:domain rdf:resource="#MaintenancePersonnel"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  <rdfs:comment xml:lang="en">ID number/string or liscense number
</rdfs:comment>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#thresholdHours">
  <rdfs:domain rdf:resource="#MaintenanceTask"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  <rdfs:comment xml:lang="en">rule threshold trigger</rdfs:comment>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#faultSeverity">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#inspectionDate">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#sensorValue">
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#temperatureThreshold">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#documentNumber">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#technicianLicense">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#indicatorValue">
  <rdfs:domain rdf:resource="#ConditionIndicator"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#assessmentStatus">
  <rdfs:domain rdf:resource="#HealthAssessment"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#recommendationText">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#MaintenanceRecommendation"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#hasReadingValue">
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#taskFlightHoursLimit">
  <rdfs:domain rdf:resource="#MaintenanceTask"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#taskFlightCyclesLimit">
  <rdfs:domain rdf:resource="#MaintenanceTask"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#currentFlightCycles">
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#currentFlightHours">
  <rdfs:domain rdf:resource="#Component"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#cyclesSinceLastNDT">
  <rdfs:domain rdf:resource="#Component"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#timeSinceNew">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#AircraftComponent"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#cyclesSinceNew">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#AircraftComponent"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#hasMaxCycles">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#AircraftComponent"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#hasRemainingDays">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#MEL_Deferral"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:AnnotationProperty rdf:about="#adreference"/>

<owl:AnnotationProperty rdf:about="#ammReference"/>

<owl:AnnotationProperty rdf:about="#effectivity"/>

<owl:AnnotationProperty rdf:about="#estimatedManHours"/>

<owl:AnnotationProperty rdf:about="#example"/>

<owl:AnnotationProperty rdf:about="#ipcNumber"/>

<owl:AnnotationProperty rdf:about="#referenceMetadata"/>

<owl:AnnotationProperty rdf:about="#requiredCertification"/>

<owl:AnnotationProperty rdf:about="#sbReference"/>

<owl:AnnotationProperty rdf:about="#toolRequirementNote"/>

<owl:Class rdf:about="#Fault">
  <rdfs:label xml:lang="en">Fault
</rdfs:label>
  <rdfs:comment xml:lang="en">An abnormal condition requiring maintenance</rdfs:comment>
  <example xml:lang="en">fuel leak</example>
</owl:Class>

<owl:Class rdf:about="#SensorData">
  <rdfs:label xml:lang="en">SensorData</rdfs:label>
  <rdfs:comment xml:lang="en">Recorded numerical or symbolic data generated by onboard sensors to monitor aircraft component health</rdfs:comment>
  <example xml:lang="en">Vibration reading from N1 fan sensor.</example>
</owl:Class>

<owl:Class rdf:about="#AircraftComponent">
  <rdfs:label xml:lang="en">AircraftComponent</rdfs:label>
  <rdfs:comment xml:lang="en">A subsystem or replaceable unit</rdfs:comment>
  <example xml:lang="en">Wing</example>
</owl:Class>

<owl:Class rdf:about="#MaintenanceProcess">
  <rdfs:subClassOf rdf:resource="#Maintenance"/>
  <rdfs:label xml:lang="en">MaintenanceProcess</rdfs:label>
  <rdfs:comment xml:lang="en">High-level structured maintenance workflow</rdfs:comment>
  <example xml:lang="en">engine overhaul</example>
</owl:Class>

<owl:Class rdf:about="#RegulatoryRequirement">
  <rdfs:label xml:lang="en">RegulatoryRequirement</rdfs:label>
  <rdfs:comment xml:lang="en">Airworthiness, maintenance, or safety rule mandated by aviation authority or OEM.</rdfs:comment>
  <example xml:lang="en">EASA CS 25.571 Damage Tolerance</example>
</owl:Class>

<owl:Class rdf:about="#MaintenancePersonnel">
  <rdfs:label xml:lang="en">MaintenancePersonnel</rdfs:label>
  <rdfs:comment xml:lang="en">Human performing maintenance.</rdfs:comment>
  <example xml:lang="en">level 3 technician</example>
</owl:Class>

<owl:Class rdf:about="#MantenanceDocument">
  <rdfs:subClassOf rdf:resource="#RegulatoryRequirement"/>
</owl:Class>

<owl:Class rdf:about="#MaintenanceProcedure">
  <rdfs:subClassOf rdf:resource="#MaintenanceProcess"/>
  <rdfs:label xml:lang="en">MaintenanceProcedure</rdfs:label>
  <rdfs:comment xml:lang="en">AMM Ch. 72–00</rdfs:comment>
  <rdfs:comment xml:lang="en">Step-by-step instructions.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#MaintenanceTask">
  <rdfs:subClassOf rdf:resource="#MaintenanceActivity"/>
  <rdfs:label xml:lang="en">MaintenanceTask</rdfs:label>
  <rdfs:comment xml:lang="en">Smallest actionable maintenance unit.</rdfs:comment>
  <example xml:lang="en">tighten bolt</example>
</owl:Class>

<owl:Class rdf:about="#Aircraft">
  <rdfs:label xml:lang="en">Aircraft</rdfs:label>
  <example xml:lang="en">Boeing 737</example>
  <rdfs:comment xml:lang="en">Represents the whole aircraft asse</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#FlightOperation">
  <rdfs:label xml:lang="en">FlightOperation</rdfs:label>
  <rdfs:comment xml:lang="en">Represents a completed operation.</rdfs:comment>
  <example xml:lang="en">flight Lagos–Abuja</example>
</owl:Class>

<owl:Class rdf:about="#OperationalMetric">
  <rdfs:subClassOf rdf:resource="#FlightOperation"/>
</owl:Class>

<owl:Class rdf:about="#Part">
  <rdfs:subClassOf rdf:resource="#MaintenanceResources"/>
  <rdfs:label xml:lang="en">Part</rdfs:label>
  <rdfs:comment xml:lang="en">A physical object used in maintenance activities for replacement, repair, or assembly of an aircraft component.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#MaintenancePlan">
  <rdfs:subClassOf rdf:resource="#MaintenanceProcess"/>
</owl:Class>

<owl:Class rdf:about="#MaintenanceSchedule">
  <rdfs:subClassOf rdf:resource="#MaintenanceProcess"/>
  <rdfs:label xml:lang="en">MaintenanceSchedule</rdfs:label>
  <rdfs:label xml:lang="en">Plan for periodic maintenance.</rdfs:label>
</owl:Class>

<owl:Class rdf:about="#MaintenanceTools">
  <rdfs:subClassOf rdf:resource="#MaintenanceResources"/>
</owl:Class>

<owl:Class rdf:about="#MaintenanceRecord">
  <rdfs:subClassOf rdf:resource="#MaintenanceProcess"/>
  <rdfs:label xml:lang="en">MaintenanceRecord</rdfs:label>
  <rdfs:comment xml:lang="en">Evidence of performed work</rdfs:comment>
  <example xml:lang="en">signed workcard</example>
</owl:Class>

<owl:Class rdf:about="#FlightCycles">
  <rdfs:subClassOf rdf:resource="#OperationalMetric"/>
  <rdfs:label xml:lang="en">FlightCycles</rdfs:label>
  <example xml:lang="en">12,100 cycles</example>
  <rdfs:comment xml:lang="en">Takeoff/landing cycle count.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#FlightHours">
  <rdfs:subClassOf rdf:resource="#OperationalMetric"/>
  <rdfs:label xml:lang="en">FlightHours</rdfs:label>
  <example xml:lang="en">24,589 hours</example>
  <rdfs:comment xml:lang="en">total Time airborne.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#MaintenanceActivity">
  <rdfs:subClassOf rdf:resource="#MaintenanceProcess"/>
  <rdfs:label xml:lang="en">MaintenanceActivity</rdfs:label>
  <rdfs:comment xml:lang="en">Work performed as part of a process.</rdfs:comment>
  <rdfs:comment xml:lang="en">engine inspection</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#ConditionIndicator">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#AircraftStatus">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#AMM_Chapter">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#LicenseType">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#HealthAssessment">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#MaintenanceRecommendation">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Component">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#MEL_Deferral">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Maintenance"/>

<owl:Class rdf:about="#MaintenanceResources"/>

<owl:Class rdf:about="#A-Check">
  <rdfs:subClassOf rdf:resource="#MaintenanceSchedule"/>
</owl:Class>

<owl:Class rdf:about="#AMM">
  <rdfs:subClassOf rdf:resource="#MantenanceDocument"/>
