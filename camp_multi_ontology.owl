<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xml:base="http://www.semanticweb.org/dell/ontologies/2025/11/CAMP-MOA"
         xmlns="http://www.semanticweb.org/dell/ontologies/2025/11/CAMP-MOA#"
         xmlns:struct="http://www.semanticweb.org/dell/ontologies/2025/11/CAMP-L1-Structural#"
         xmlns:func="http://www.semanticweb.org/dell/ontologies/2025/11/CAMP-L2-Functional#"
         xmlns:behav="http://www.semanticweb.org/dell/ontologies/2025/11/CAMP-L3-Behavioral#"
         xmlns:mon="http://www.semanticweb.org/dell/ontologies/2025/11/CAMP-L4-Monitoring#"
         xmlns:maint="http://www.semanticweb.org/dell/ontologies/2025/11/CAMP-L5-Maintenance#"
         xmlns:life="http://www.semanticweb.org/dell/ontologies/2025/11/CAMP-L6-Lifecycle#"
         xmlns:env="http://www.semanticweb.org/dell/ontologies/2025/11/CAMP-L7-Environmental#"
         xmlns:base="http://www.semanticweb.org/dell/ontologies/2025/11/MyCampSystem#">

<!-- ============================================================ -->
<!--   CAMP Multi-Ontology Architecture (MOA)                     -->
<!--   Aircraft Comprehensive Maintenance Programme               -->
<!--   7-Layer Stack + Cross-Ontology Mappings + AI Reasoning     -->
<!--   Extends: MyCampSystem (base layer)                         -->
<!-- ============================================================ -->

<owl:Ontology rdf:about="http://www.semanticweb.org/dell/ontologies/2025/11/CAMP-MOA">
  <rdfs:label xml:lang="en">CAMP Multi-Ontology Architecture</rdfs:label>
  <rdfs:comment xml:lang="en">
    Seven-layer multi-ontology architecture for the Comprehensive Aircraft Maintenance Programme (CAMP).
    Layers: (1) Structural, (2) Functional, (3) Behavioral, (4) Monitoring,
            (5) Maintenance, (6) Lifecycle, (7) Environmental.
    Includes cross-ontology alignment axioms and an AI Reasoning Engine bridge.
  </rdfs:comment>
  <dc:creator>CAMP MOA Ontology Engineer</dc:creator>
  <dc:date>2025-11-01</dc:date>
  <owl:imports rdf:resource="http://www.semanticweb.org/dell/ontologies/2025/11/MyCampSystem"/>
  <owl:versionInfo>2.0.0</owl:versionInfo>
</owl:Ontology>


<!-- ================================================================ -->
<!-- LAYER 1 — STRUCTURAL ONTOLOGY (Physical Hierarchy)               -->
<!-- http://www.semanticweb.org/dell/ontologies/2025/11/CAMP-L1-Structural -->
<!-- ================================================================ -->

<!-- ── Sub-ontology declaration ── -->
<owl:Ontology rdf:about="http://www.semanticweb.org/dell/ontologies/2025/11/CAMP-L1-Structural">
  <rdfs:label xml:lang="en">Layer 1 – Structural Ontology</rdfs:label>
  <rdfs:comment xml:lang="en">Models the physical decomposition of the aircraft from airframe down to individual parts (ATA chapter aligned).</rdfs:comment>
</owl:Ontology>

<!-- Object Properties – L1 -->
<owl:ObjectProperty rdf:about="#L1_isPartOf">
  <rdfs:label xml:lang="en">isPartOf</rdfs:label>
  <rdfs:comment xml:lang="en">Mereological containment: a physical part belongs to a parent assembly.</rdfs:comment>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
  <rdfs:domain rdf:resource="#L1_PhysicalEntity"/>
  <rdfs:range rdf:resource="#L1_PhysicalEntity"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#L1_hasSubAssembly">
  <owl:inverseOf rdf:resource="#L1_isPartOf"/>
  <rdfs:label xml:lang="en">hasSubAssembly</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#L1_installedOn">
  <rdfs:label xml:lang="en">installedOn</rdfs:label>
  <rdfs:comment xml:lang="en">Links a physical part or LRU to the aircraft or assembly it is currently installed on.</rdfs:comment>
  <rdfs:domain rdf:resource="#L1_PhysicalEntity"/>
  <rdfs:range rdf:resource="#L1_AircraftSystem"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#L1_hasATAChapter">
  <rdfs:label xml:lang="en">hasATAChapter</rdfs:label>
  <rdfs:comment xml:lang="en">Associates a component with its ATA 100 chapter classification.</rdfs:comment>
  <rdfs:domain rdf:resource="#L1_PhysicalEntity"/>
  <rdfs:range rdf:resource="#L1_ATAChapter"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#L1_hasZone">
  <rdfs:label xml:lang="en">hasZone</rdfs:label>
  <rdfs:comment xml:lang="en">Maps a physical entity to an aircraft zone (Boeing/Airbus zone numbering).</rdfs:comment>
  <rdfs:domain rdf:resource="#L1_PhysicalEntity"/>
  <rdfs:range rdf:resource="#L1_AircraftZone"/>
</owl:ObjectProperty>

<!-- Datatype Properties – L1 -->
<owl:DatatypeProperty rdf:about="#L1_partNumber">
  <rdfs:label xml:lang="en">partNumber</rdfs:label>
  <rdfs:domain rdf:resource="#L1_PhysicalEntity"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#L1_serialNumber">
  <rdfs:label xml:lang="en">serialNumber</rdfs:label>
  <rdfs:domain rdf:resource="#L1_PhysicalEntity"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#L1_weight_kg">
  <rdfs:label xml:lang="en">weight_kg</rdfs:label>
  <rdfs:domain rdf:resource="#L1_PhysicalEntity"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#L1_ataChapterCode">
  <rdfs:label xml:lang="en">ataChapterCode</rdfs:label>
  <rdfs:domain rdf:resource="#L1_ATAChapter"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#L1_zoneCode">
  <rdfs:label xml:lang="en">zoneCode</rdfs:label>
  <rdfs:domain rdf:resource="#L1_AircraftZone"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<!-- Classes – L1 -->
<owl:Class rdf:about="#L1_PhysicalEntity">
  <rdfs:label xml:lang="en">PhysicalEntity</rdfs:label>
  <rdfs:comment xml:lang="en">Root class for all tangible aircraft hardware objects.</rdfs:comment>
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <!-- Bridge to base ontology -->
  <owl:equivalentClass rdf:resource="base:AircraftComponent"/>
</owl:Class>

<owl:Class rdf:about="#L1_AircraftSystem">
  <rdfs:subClassOf rdf:resource="#L1_PhysicalEntity"/>
  <rdfs:label xml:lang="en">AircraftSystem</rdfs:label>
  <rdfs:comment xml:lang="en">A top-level system grouping (e.g. propulsion, avionics, hydraulics).</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#L1_Airframe">
  <rdfs:subClassOf rdf:resource="#L1_AircraftSystem"/>
  <rdfs:label xml:lang="en">Airframe</rdfs:label>
  <rdfs:comment xml:lang="en">Primary structure: fuselage, wings, empennage, nacelles, pylons.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#L1_PropulsionSystem">
  <rdfs:subClassOf rdf:resource="#L1_AircraftSystem"/>
  <rdfs:label xml:lang="en">PropulsionSystem</rdfs:label>
  <rdfs:comment xml:lang="en">Engine, APU, and associated thrust-generating components.</rdfs:comment>
  <owl:equivalentClass rdf:resource="base:Engine"/>
</owl:Class>

<owl:Class rdf:about="#L1_HydraulicSystem">
  <rdfs:subClassOf rdf:resource="#L1_AircraftSystem"/>
  <rdfs:label xml:lang="en">HydraulicSystem</rdfs:label>
  <rdfs:comment xml:lang="en">Hydraulic generation, distribution, and actuation subsystem.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#L1_FuelSystem">
  <rdfs:subClassOf rdf:resource="#L1_AircraftSystem"/>
  <rdfs:label xml:lang="en">FuelSystem</rdfs:label>
  <rdfs:comment xml:lang="en">Fuel storage, management, and transfer system.</rdfs:comment>
  <owl:equivalentClass rdf:resource="base:FuelTank"/>
</owl:Class>

<owl:Class rdf:about="#L1_AvionicsSystem">
  <rdfs:subClassOf rdf:resource="#L1_AircraftSystem"/>
  <rdfs:label xml:lang="en">AvionicsSystem</rdfs:label>
  <rdfs:comment xml:lang="en">Flight management, communication, and navigation avionics.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#L1_LandingGearSystem">
  <rdfs:subClassOf rdf:resource="#L1_AircraftSystem"/>
  <rdfs:label xml:lang="en">LandingGearSystem</rdfs:label>
  <rdfs:comment xml:lang="en">Main and nose landing gear, brakes, steering, and doors.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#L1_LifeReplaceableUnit">
  <rdfs:subClassOf rdf:resource="#L1_PhysicalEntity"/>
  <rdfs:label xml:lang="en">LineReplaceableUnit</rdfs:label>
  <rdfs:comment xml:lang="en">LRU — a component replaceable at line maintenance level.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#L1_ShopReplaceableUnit">
  <rdfs:subClassOf rdf:resource="#L1_PhysicalEntity"/>
  <rdfs:label xml:lang="en">ShopReplaceableUnit</rdfs:label>
  <rdfs:comment xml:lang="en">SRU — component replaceable only in a shop/overhaul environment.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#L1_ATAChapter">
  <rdfs:label xml:lang="en">ATAChapter</rdfs:label>
  <rdfs:comment xml:lang="en">ATA 100 chapter classification node (e.g. ATA 71 — Power Plant).</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#L1_AircraftZone">
  <rdfs:label xml:lang="en">AircraftZone</rdfs:label>
  <rdfs:comment xml:lang="en">Spatial zone on the aircraft (100-series fuselage, 500-series empennage, etc.).</rdfs:comment>
</owl:Class>

<!-- Do-328 Structural Instances -->
<owl:NamedIndividual rdf:about="#L1_Do328_001">
  <rdf:type rdf:resource="#L1_AircraftSystem"/>
  <rdfs:label xml:lang="en">Dornier Do 328-100 (MSN 001)</rdfs:label>
  <L1_serialNumber>Do328-MSN-001</L1_serialNumber>
  <L1_isPartOf rdf:resource="base:Aircraft_Do328_001"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#L1_ATA71_PowerPlant">
  <rdf:type rdf:resource="#L1_ATAChapter"/>
  <rdfs:label xml:lang="en">ATA 71 — Power Plant</rdfs:label>
  <L1_ataChapterCode>71</L1_ataChapterCode>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#L1_ATA28_FuelSystem">
  <rdf:type rdf:resource="#L1_ATAChapter"/>
  <rdfs:label xml:lang="en">ATA 28 — Fuel</rdfs:label>
  <L1_ataChapterCode>28</L1_ataChapterCode>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#L1_ATA57_Wings">
  <rdf:type rdf:resource="#L1_ATAChapter"/>
  <rdfs:label xml:lang="en">ATA 57 — Wings</rdfs:label>
  <L1_ataChapterCode>57</L1_ataChapterCode>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#L1_Zone500_Empennage">
  <rdf:type rdf:resource="#L1_AircraftZone"/>
  <rdfs:label xml:lang="en">Zone 500 — Empennage</rdfs:label>
  <L1_zoneCode>500</L1_zoneCode>
</owl:NamedIndividual>


<!-- ================================================================ -->
<!-- LAYER 2 — FUNCTIONAL ONTOLOGY (Component Functions)              -->
<!-- http://www.semanticweb.org/dell/ontologies/2025/11/CAMP-L2-Functional -->
<!-- ================================================================ -->

<owl:Ontology rdf:about="http://www.semanticweb.org/dell/ontologies/2025/11/CAMP-L2-Functional">
  <rdfs:label xml:lang="en">Layer 2 – Functional Ontology</rdfs:label>
  <rdfs:comment xml:lang="en">Captures what each component does — its functions, performance parameters, and functional dependencies.</rdfs:comment>
</owl:Ontology>

<!-- Object Properties – L2 -->
<owl:ObjectProperty rdf:about="#L2_performs">
  <rdfs:label xml:lang="en">performs</rdfs:label>
  <rdfs:comment xml:lang="en">Links a physical component (L1) to its assigned function (L2).</rdfs:comment>
  <rdfs:domain rdf:resource="#L1_PhysicalEntity"/>
  <rdfs:range rdf:resource="#L2_Function"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#L2_dependsOnFunction">
  <rdfs:label xml:lang="en">dependsOnFunction</rdfs:label>
  <rdfs:comment xml:lang="en">Functional dependency — this function requires another function to be operative.</rdfs:comment>
  <rdfs:domain rdf:resource="#L2_Function"/>
  <rdfs:range rdf:resource="#L2_Function"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#L2_hasPerformanceParameter">
  <rdfs:label xml:lang="en">hasPerformanceParameter</rdfs:label>
  <rdfs:domain rdf:resource="#L2_Function"/>
  <rdfs:range rdf:resource="#L2_PerformanceParameter"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#L2_hasFunctionalRequirement">
  <rdfs:label xml:lang="en">hasFunctionalRequirement</rdfs:label>
  <rdfs:comment xml:lang="en">Design or certification requirement governing a function.</rdfs:comment>
  <rdfs:domain rdf:resource="#L2_Function"/>
  <rdfs:range rdf:resource="#L2_FunctionalRequirement"/>
</owl:ObjectProperty>

<!-- Datatype Properties – L2 -->
<owl:DatatypeProperty rdf:about="#L2_nominalValue">
  <rdfs:label xml:lang="en">nominalValue</rdfs:label>
  <rdfs:domain rdf:resource="#L2_PerformanceParameter"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#L2_unit">
  <rdfs:label xml:lang="en">unit</rdfs:label>
  <rdfs:domain rdf:resource="#L2_PerformanceParameter"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#L2_minValue">
  <rdfs:label xml:lang="en">minValue</rdfs:label>
  <rdfs:domain rdf:resource="#L2_PerformanceParameter"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#L2_maxValue">
  <rdfs:label xml:lang="en">maxValue</rdfs:label>
  <rdfs:domain rdf:resource="#L2_PerformanceParameter"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#L2_functionDescription">
  <rdfs:label xml:lang="en">functionDescription</rdfs:label>
  <rdfs:domain rdf:resource="#L2_Function"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<!-- Classes – L2 -->
<owl:Class rdf:about="#L2_Function">
  <rdfs:label xml:lang="en">Function</rdfs:label>
  <rdfs:comment xml:lang="en">An intended capability or behaviour of an aircraft component or system.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#L2_PropulsiveFunction">
  <rdfs:subClassOf rdf:resource="#L2_Function"/>
  <rdfs:label xml:lang="en">PropulsiveFunction</rdfs:label>
  <rdfs:comment xml:lang="en">Generates thrust to move the aircraft (e.g. turboprop power output).</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#L2_FluidManagementFunction">
  <rdfs:subClassOf rdf:resource="#L2_Function"/>
  <rdfs:label xml:lang="en">FluidManagementFunction</rdfs:label>
  <rdfs:comment xml:lang="en">Controls and distributes fluid (fuel, hydraulic, oil, bleed-air).</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#L2_StructuralSupportFunction">
  <rdfs:subClassOf rdf:resource="#L2_Function"/>
  <rdfs:label xml:lang="en">StructuralSupportFunction</rdfs:label>
  <rdfs:comment xml:lang="en">Bears loads and maintains airframe integrity.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#L2_NavigationFunction">
  <rdfs:subClassOf rdf:resource="#L2_Function"/>
  <rdfs:label xml:lang="en">NavigationFunction</rdfs:label>
  <rdfs:comment xml:lang="en">Provides position, attitude, and navigation data.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#L2_PowerGenerationFunction">
  <rdfs:subClassOf rdf:resource="#L2_Function"/>
  <rdfs:label xml:lang="en">PowerGenerationFunction</rdfs:label>
  <rdfs:comment xml:lang="en">Electrical power generation (generators, APU, batteries).</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#L2_PerformanceParameter">
  <rdfs:label xml:lang="en">PerformanceParameter</rdfs:label>
  <rdfs:comment xml:lang="en">A measurable attribute that quantifies how well a function is performed.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#L2_FunctionalRequirement">
  <rdfs:label xml:lang="en">FunctionalRequirement</rdfs:label>
  <rdfs:comment xml:lang="en">A design, airworthiness or operational requirement that a function must satisfy.</rdfs:comment>
</owl:Class>

<!-- L2 Instances -->
<owl:NamedIndividual rdf:about="#L2_ThrustGeneration_PW119">
  <rdf:type rdf:resource="#L2_PropulsiveFunction"/>
  <rdfs:label xml:lang="en">Thrust Generation – PW119</rdfs:label>
  <L2_functionDescription>Generate shaft power via turboprop cycle; rated at 1,900 SHP.</L2_functionDescription>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#L2_FuelStorage_LeftTank">
  <rdf:type rdf:resource="#L2_FluidManagementFunction"/>
  <rdfs:label xml:lang="en">Fuel Storage – Left Wing Tank</rdfs:label>
  <L2_functionDescription>Store and transfer jet fuel to the left engine feed system.</L2_functionDescription>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#L2_WingLiftGeneration">
  <rdf:type rdf:resource="#L2_StructuralSupportFunction"/>
  <rdfs:label xml:lang="en">Lift Generation – Wing</rdfs:label>
  <L2_functionDescription>Generate aerodynamic lift; support fuel tank loads and control surface loads.</L2_functionDescription>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#L2_EGT_NominalParam">
  <rdf:type rdf:resource="#L2_PerformanceParameter"/>
  <rdfs:label xml:lang="en">EGT Nominal Range</rdfs:label>
  <L2_nominalValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">750.0</L2_nominalValue>
  <L2_maxValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">800.0</L2_maxValue>
  <L2_minValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">400.0</L2_minValue>
  <L2_unit>°C</L2_unit>
</owl:NamedIndividual>

<!-- Cross-link: L1 → L2 -->
<owl:NamedIndividual rdf:about="base:PW119_Engine_Left">
  <L2_performs rdf:resource="#L2_ThrustGeneration_PW119"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="base:Left_Wing_FuelTank">
  <L2_performs rdf:resource="#L2_FuelStorage_LeftTank"/>
</owl:NamedIndividual>


<!-- ================================================================ -->
<!-- LAYER 3 — BEHAVIORAL ONTOLOGY (States & Failure Modes)           -->
<!-- http://www.semanticweb.org/dell/ontologies/2025/11/CAMP-L3-Behavioral -->
<!-- ================================================================ -->

<owl:Ontology rdf:about="http://www.semanticweb.org/dell/ontologies/2025/11/CAMP-L3-Behavioral">
  <rdfs:label xml:lang="en">Layer 3 – Behavioral Ontology</rdfs:label>
  <rdfs:comment xml:lang="en">Represents component and system states, state transitions, failure modes, and effects (FMEA aligned).</rdfs:comment>
</owl:Ontology>

<!-- Object Properties – L3 -->
<owl:ObjectProperty rdf:about="#L3_hasState">
  <rdfs:label xml:lang="en">hasState</rdfs:label>
  <rdfs:comment xml:lang="en">Current operational state of a physical entity.</rdfs:comment>
  <rdfs:domain rdf:resource="#L1_PhysicalEntity"/>
  <rdfs:range rdf:resource="#L3_OperationalState"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#L3_transitionsTo">
  <rdfs:label xml:lang="en">transitionsTo</rdfs:label>
  <rdfs:comment xml:lang="en">Valid state transition from one state to another.</rdfs:comment>
  <rdfs:domain rdf:resource="#L3_OperationalState"/>
  <rdfs:range rdf:resource="#L3_OperationalState"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#L3_hasFailureMode">
  <rdfs:label xml:lang="en">hasFailureMode</rdfs:label>
  <rdfs:comment xml:lang="en">Associates a component with its possible failure modes (FMEA).</rdfs:comment>
  <rdfs:domain rdf:resource="#L1_PhysicalEntity"/>
  <rdfs:range rdf:resource="#L3_FailureMode"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#L3_hasEffect">
  <rdfs:label xml:lang="en">hasEffect</rdfs:label>
  <rdfs:comment xml:lang="en">Effect chain: failure mode causes an effect at component or system level.</rdfs:comment>
  <rdfs:domain rdf:resource="#L3_FailureMode"/>
  <rdfs:range rdf:resource="#L3_FailureEffect"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#L3_mitigatedBy">
  <rdfs:label xml:lang="en">mitigatedBy</rdfs:label>
  <rdfs:comment xml:lang="en">Links a failure mode to a maintenance task that mitigates or corrects it (L5 cross-link).</rdfs:comment>
  <rdfs:domain rdf:resource="#L3_FailureMode"/>
  <rdfs:range rdf:resource="base:MaintenanceTask"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#L3_causedByFault">
  <rdfs:label xml:lang="en">causedByFault</rdfs:label>
  <rdfs:comment xml:lang="en">Links a failure mode to its root cause fault (base ontology bridge).</rdfs:comment>
  <rdfs:domain rdf:resource="#L3_FailureMode"/>
  <rdfs:range rdf:resource="base:Fault"/>
</owl:ObjectProperty>

<!-- Datatype Properties – L3 -->
<owl:DatatypeProperty rdf:about="#L3_rpnScore">
  <rdfs:label xml:lang="en">rpnScore</rdfs:label>
  <rdfs:comment xml:lang="en">Risk Priority Number = Severity × Occurrence × Detection (FMEA).</rdfs:comment>
  <rdfs:domain rdf:resource="#L3_FailureMode"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#L3_severity">
  <rdfs:label xml:lang="en">severity</rdfs:label>
  <rdfs:domain rdf:resource="#L3_FailureMode"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#L3_occurrence">
  <rdfs:label xml:lang="en">occurrence</rdfs:label>
  <rdfs:domain rdf:resource="#L3_FailureMode"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#L3_detection">
  <rdfs:label xml:lang="en">detection</rdfs:label>
  <rdfs:domain rdf:resource="#L3_FailureMode"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#L3_stateName">
  <rdfs:label xml:lang="en">stateName</rdfs:label>
  <rdfs:domain rdf:resource="#L3_OperationalState"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<!-- Classes – L3 -->
<owl:Class rdf:about="#L3_OperationalState">
  <rdfs:label xml:lang="en">OperationalState</rdfs:label>
  <rdfs:comment xml:lang="en">The current condition of a component from a functional standpoint.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#L3_NominalState">
  <rdfs:subClassOf rdf:resource="#L3_OperationalState"/>
  <rdfs:label xml:lang="en">NominalState</rdfs:label>
  <rdfs:comment xml:lang="en">Component operating within all design limits.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#L3_DegradedState">
  <rdfs:subClassOf rdf:resource="#L3_OperationalState"/>
  <rdfs:label xml:lang="en">DegradedState</rdfs:label>
  <rdfs:comment xml:lang="en">Component functional but outside optimal parameters; dispatch may be permitted with MEL.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#L3_FailedState">
  <rdfs:subClassOf rdf:resource="#L3_OperationalState"/>
  <rdfs:label xml:lang="en">FailedState</rdfs:label>
  <rdfs:comment xml:lang="en">Component has lost its intended function; aircraft is non-airworthy pending maintenance.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#L3_UnderMaintenanceState">
  <rdfs:subClassOf rdf:resource="#L3_OperationalState"/>
  <rdfs:label xml:lang="en">UnderMaintenanceState</rdfs:label>
  <rdfs:comment xml:lang="en">Component removed from service for scheduled or unscheduled maintenance.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#L3_FailureMode">
  <rdfs:label xml:lang="en">FailureMode</rdfs:label>
  <rdfs:comment xml:lang="en">The manner in which a component fails — aligned to FMEA/MSG-3 methodology.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#L3_StructuralFailureMode">
  <rdfs:subClassOf rdf:resource="#L3_FailureMode"/>
  <rdfs:label xml:lang="en">StructuralFailureMode</rdfs:label>
</owl:Class>

<owl:Class rdf:about="#L3_FunctionalFailureMode">
  <rdfs:subClassOf rdf:resource="#L3_FailureMode"/>
  <rdfs:label xml:lang="en">FunctionalFailureMode</rdfs:label>
</owl:Class>

<owl:Class rdf:about="#L3_LeakageFailureMode">
  <rdfs:subClassOf rdf:resource="#L3_FailureMode"/>
  <rdfs:label xml:lang="en">LeakageFailureMode</rdfs:label>
</owl:Class>

<owl:Class rdf:about="#L3_WearFailureMode">
  <rdfs:subClassOf rdf:resource="#L3_FailureMode"/>
  <rdfs:label xml:lang="en">WearFailureMode</rdfs:label>
</owl:Class>

<owl:Class rdf:about="#L3_FailureEffect">
  <rdfs:label xml:lang="en">FailureEffect</rdfs:label>
  <rdfs:comment xml:lang="en">The consequence of a failure mode at component, system, or aircraft level.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#L3_SafetyEffect">
  <rdfs:subClassOf rdf:resource="#L3_FailureEffect"/>
  <rdfs:label xml:lang="en">SafetyEffect</rdfs:label>
</owl:Class>

<owl:Class rdf:about="#L3_OperationalEffect">
  <rdfs:subClassOf rdf:resource="#L3_FailureEffect"/>
  <rdfs:label xml:lang="en">OperationalEffect</rdfs:label>
</owl:Class>

<owl:Class rdf:about="#L3_EconomicEffect">
  <rdfs:subClassOf rdf:resource="#L3_FailureEffect"/>
  <rdfs:label xml:lang="en">EconomicEffect</rdfs:label>
</owl:Class>

