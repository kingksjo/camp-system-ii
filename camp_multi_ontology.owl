<!-- ================================================================ -->
<!-- LAYER 5 — MAINTENANCE ONTOLOGY (Tasks & Regulations)             -->
<!-- http://www.semanticweb.org/dell/ontologies/2025/11/CAMP-L5-Maintenance -->
<!-- ================================================================ -->

<owl:Ontology rdf:about="http://www.semanticweb.org/dell/ontologies/2025/11/CAMP-L5-Maintenance">
  <rdfs:label xml:lang="en">Layer 5 – Maintenance Ontology</rdfs:label>
  <rdfs:comment xml:lang="en">Extends the base MyCampSystem maintenance classes with task planning, work packages, regulatory compliance (AD/SB/MPD), and resource allocation.</rdfs:comment>
</owl:Ontology>

<!-- Object Properties – L5 -->
<owl:ObjectProperty rdf:about="#L5_groupedInWorkPackage">
  <rdfs:label xml:lang="en">groupedInWorkPackage</rdfs:label>
  <rdfs:comment xml:lang="en">Maintenance tasks grouped into a structured work package.</rdfs:comment>
  <rdfs:domain rdf:resource="base:MaintenanceTask"/>
  <rdfs:range rdf:resource="#L5_WorkPackage"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#L5_hasComplianceStatus">
  <rdfs:label xml:lang="en">hasComplianceStatus</rdfs:label>
  <rdfs:domain rdf:resource="#L5_WorkPackage"/>
  <rdfs:range rdf:resource="#L5_ComplianceStatus"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#L5_referencesTask">
  <rdfs:label xml:lang="en">referencesTask</rdfs:label>
  <rdfs:comment xml:lang="en">Links an MPD task card to the maintenance task it defines.</rdfs:comment>
  <rdfs:domain rdf:resource="#L5_MPDTaskCard"/>
  <rdfs:range rdf:resource="base:MaintenanceTask"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#L5_tracedToAD">
  <rdfs:label xml:lang="en">tracedToAD</rdfs:label>
  <rdfs:comment xml:lang="en">Compliance traceability from a task or work package to a mandatory Airworthiness Directive.</rdfs:comment>
  <rdfs:domain rdf:resource="#L5_WorkPackage"/>
  <rdfs:range rdf:resource="base:AirworthinessDirective"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#L5_estimatesDowntime">
  <rdfs:label xml:lang="en">estimatesDowntime</rdfs:label>
  <rdfs:domain rdf:resource="#L5_WorkPackage"/>
  <rdfs:range rdf:resource="#L5_DowntimeEstimate"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#L5_assignedToHangar">
  <rdfs:label xml:lang="en">assignedToHangar</rdfs:label>
  <rdfs:domain rdf:resource="#L5_WorkPackage"/>
  <rdfs:range rdf:resource="#L5_MaintenanceFacility"/>
</owl:ObjectProperty>

<!-- Datatype Properties – L5 -->
<owl:DatatypeProperty rdf:about="#L5_workPackageID">
  <rdfs:label xml:lang="en">workPackageID</rdfs:label>
  <rdfs:domain rdf:resource="#L5_WorkPackage"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#L5_plannedStartDate">
  <rdfs:domain rdf:resource="#L5_WorkPackage"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#L5_plannedEndDate">
  <rdfs:domain rdf:resource="#L5_WorkPackage"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#L5_estimatedManHours">
  <rdfs:domain rdf:resource="#L5_WorkPackage"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#L5_mpdTaskNumber">
  <rdfs:label xml:lang="en">mpdTaskNumber</rdfs:label>
  <rdfs:domain rdf:resource="#L5_MPDTaskCard"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#L5_facilityICAO">
  <rdfs:label xml:lang="en">facilityICAO</rdfs:label>
  <rdfs:domain rdf:resource="#L5_MaintenanceFacility"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<!-- Classes – L5 -->
<owl:Class rdf:about="#L5_WorkPackage">
  <rdfs:label xml:lang="en">WorkPackage</rdfs:label>
  <rdfs:comment xml:lang="en">A bundled set of maintenance tasks planned for a specific aircraft visit.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#L5_LineWorkPackage">
  <rdfs:subClassOf rdf:resource="#L5_WorkPackage"/>
  <rdfs:label xml:lang="en">LineWorkPackage</rdfs:label>
</owl:Class>

<owl:Class rdf:about="#L5_HeavyWorkPackage">
  <rdfs:subClassOf rdf:resource="#L5_WorkPackage"/>
  <rdfs:label xml:lang="en">HeavyWorkPackage</rdfs:label>
  <rdfs:comment xml:lang="en">C-Check or D-Check level work package.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#L5_MPDTaskCard">
  <rdfs:label xml:lang="en">MPDTaskCard</rdfs:label>
  <rdfs:comment xml:lang="en">Maintenance Planning Document task card defining an interval-based maintenance requirement.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#L5_ComplianceStatus">
  <rdfs:label xml:lang="en">ComplianceStatus</rdfs:label>
  <rdfs:comment xml:lang="en">Regulatory compliance status of a work package (Open, In-Progress, Closed, Overdue).</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#L5_MaintenanceFacility">
  <rdfs:label xml:lang="en">MaintenanceFacility</rdfs:label>
  <rdfs:comment xml:lang="en">A licensed MRO facility where maintenance is performed.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#L5_DowntimeEstimate">
  <rdfs:label xml:lang="en">DowntimeEstimate</rdfs:label>
</owl:Class>

