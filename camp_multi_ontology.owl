<!-- AI REASONING ENGINE — Cross-Ontology Bridge                      -->
<!-- ================================================================ -->

<owl:Ontology rdf:about="http://www.semanticweb.org/dell/ontologies/2025/11/CAMP-AIEngine">
  <rdfs:label xml:lang="en">CAMP AI Reasoning Engine</rdfs:label>
  <rdfs:comment xml:lang="en">Meta-layer that coordinates reasoning across all seven layers: ingests real-time telemetry (L4), evaluates against behavioral models (L3), queries lifecycle history (L6), incorporates environmental context (L7), and generates maintenance recommendations (L5) for compliant task execution.</rdfs:comment>
</owl:Ontology>

<!-- Object Properties – AI Engine -->
<owl:ObjectProperty rdf:about="#AI_ingestsStream">
  <rdfs:label xml:lang="en">ingestsStream</rdfs:label>
  <rdfs:domain rdf:resource="#AI_ReasoningEngine"/>
  <rdfs:range rdf:resource="#L4_TelemetryStream"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#AI_evaluatesAgainst">
  <rdfs:label xml:lang="en">evaluatesAgainst</rdfs:label>
  <rdfs:domain rdf:resource="#AI_ReasoningEngine"/>
  <rdfs:range rdf:resource="#L3_FailureMode"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#AI_queriesLifecycle">
  <rdfs:label xml:lang="en">queriesLifecycle</rdfs:label>
  <rdfs:domain rdf:resource="#AI_ReasoningEngine"/>
  <rdfs:range rdf:resource="#L6_ComponentRecord"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#AI_appliesEnvironmentalContext">
  <rdfs:label xml:lang="en">appliesEnvironmentalContext</rdfs:label>
  <rdfs:domain rdf:resource="#AI_ReasoningEngine"/>
  <rdfs:range rdf:resource="#L7_OperatingEnvironment"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#AI_generates">
  <rdfs:label xml:lang="en">generates</rdfs:label>
  <rdfs:comment xml:lang="en">The reasoning engine outputs a maintenance recommendation.</rdfs:comment>
  <rdfs:domain rdf:resource="#AI_ReasoningEngine"/>
  <rdfs:range rdf:resource="base:MaintenanceRecommendation"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#AI_recommendsWorkPackage">
  <rdfs:label xml:lang="en">recommendsWorkPackage</rdfs:label>
  <rdfs:domain rdf:resource="#AI_ReasoningEngine"/>
  <rdfs:range rdf:resource="#L5_WorkPackage"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#AI_usesReasoningMethod">
  <rdfs:label xml:lang="en">usesReasoningMethod</rdfs:label>
  <rdfs:domain rdf:resource="#AI_ReasoningEngine"/>
  <rdfs:range rdf:resource="#AI_ReasoningMethod"/>
</owl:ObjectProperty>

<!-- Datatype Properties – AI Engine -->
<owl:DatatypeProperty rdf:about="#AI_confidenceScore">
  <rdfs:label xml:lang="en">confidenceScore</rdfs:label>
  <rdfs:comment xml:lang="en">0.0–1.0 confidence in the generated recommendation.</rdfs:comment>
  <rdfs:domain rdf:resource="base:MaintenanceRecommendation"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#AI_urgencyLevel">
  <rdfs:label xml:lang="en">urgencyLevel</rdfs:label>
  <rdfs:comment xml:lang="en">Immediate / Within24h / NextScheduled / Monitor</rdfs:comment>
  <rdfs:domain rdf:resource="base:MaintenanceRecommendation"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#AI_rulesFired">
  <rdfs:label xml:lang="en">rulesFired</rdfs:label>
  <rdfs:comment xml:lang="en">SWRL/SPARQL rules triggered during reasoning.</rdfs:comment>
  <rdfs:domain rdf:resource="#AI_ReasoningSession"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<!-- Classes – AI Engine -->
<owl:Class rdf:about="#AI_ReasoningEngine">
  <rdfs:label xml:lang="en">AIReasoningEngine</rdfs:label>
  <rdfs:comment xml:lang="en">The AI/ML + OWL-reasoner component that integrates all seven ontology layers to generate predictive and prescriptive maintenance intelligence.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#AI_ReasoningMethod">
  <rdfs:label xml:lang="en">ReasoningMethod</rdfs:label>
</owl:Class>

<owl:Class rdf:about="#AI_OWLReasoning">
  <rdfs:subClassOf rdf:resource="#AI_ReasoningMethod"/>
  <rdfs:label xml:lang="en">OWL-DL Reasoning</rdfs:label>
  <rdfs:comment xml:lang="en">Description logic subsumption and consistency checking (HermiT/Pellet).</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#AI_SPARQLReasoning">
  <rdfs:subClassOf rdf:resource="#AI_ReasoningMethod"/>
  <rdfs:label xml:lang="en">SPARQL Query Reasoning</rdfs:label>
</owl:Class>

<owl:Class rdf:about="#AI_MLPredictiveModel">
  <rdfs:subClassOf rdf:resource="#AI_ReasoningMethod"/>
  <rdfs:label xml:lang="en">ML Predictive Model</rdfs:label>
  <rdfs:comment xml:lang="en">Machine learning model (LSTM, GBT) predicting RUL from telemetry trends.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#AI_SWRLRule">
  <rdfs:subClassOf rdf:resource="#AI_ReasoningMethod"/>
  <rdfs:label xml:lang="en">SWRLRule</rdfs:label>
  <rdfs:comment xml:lang="en">Semantic Web Rule Language rule executing over the ontology graph.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#AI_ReasoningSession">
  <rdfs:label xml:lang="en">ReasoningSession</rdfs:label>
  <rdfs:comment xml:lang="en">A single inference execution triggered by a monitoring alert or scheduled analysis.</rdfs:comment>
</owl:Class>

