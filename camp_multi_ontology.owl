  <rdfs:comment xml:lang="en">Environmental stress factor acting on a component, accelerating degradation.</rdfs:comment>
  <rdfs:domain rdf:resource="#L1_PhysicalEntity"/>
  <rdfs:range rdf:resource="#L7_EnvironmentalStressor"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#L7_stressorModifiesFailureMode">
  <rdfs:label xml:lang="en">stressorModifiesFailureMode</rdfs:label>
  <rdfs:comment xml:lang="en">Environmental stressor increases the probability of a behavioural failure mode (L3 cross-link).</rdfs:comment>
  <rdfs:domain rdf:resource="#L7_EnvironmentalStressor"/>
  <rdfs:range rdf:resource="#L3_FailureMode"/>
</owl:ObjectProperty>

<!-- Datatype Properties – L7 -->
<owl:DatatypeProperty rdf:about="#L7_ambientTemperature_C">
  <rdfs:domain rdf:resource="#L7_OperatingEnvironment"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#L7_humidity_pct">
