<!-- ================================================================ -->
<!-- CROSS-ONTOLOGY MAPPING AXIOMS                                     -->
<!-- Formal owl:equivalentClass, rdfs:subClassOf, and owl:sameAs      -->
<!-- alignment between layers and base ontology                        -->
<!-- ================================================================ -->

<!-- L1 ↔ Base mappings -->
<owl:Class rdf:about="#L1_PhysicalEntity">
  <rdfs:subClassOf rdf:resource="base:AircraftComponent"/>
</owl:Class>

<owl:Class rdf:about="#L1_PropulsionSystem">
  <owl:equivalentClass rdf:resource="base:Engine"/>
</owl:Class>

<owl:Class rdf:about="#L1_FuelSystem">
  <owl:equivalentClass rdf:resource="base:FuelTank"/>
</owl:Class>

<!-- L3 ↔ Base Fault alignment -->
<owl:Class rdf:about="#L3_FailureMode">
  <rdfs:subClassOf rdf:resource="base:Fault"/>
</owl:Class>

<!-- L4 ↔ Base SensorData alignment -->
<owl:Class rdf:about="#L4_TelemetryStream">
  <rdfs:subClassOf rdf:resource="base:SensorData"/>
</owl:Class>

<!-- L5 ↔ Base MaintenanceProcess alignment -->
<owl:Class rdf:about="#L5_WorkPackage">
  <rdfs:subClassOf rdf:resource="base:MaintenanceProcess"/>
</owl:Class>

<!-- L6 ↔ Base MaintenanceRecord alignment -->
<owl:Class rdf:about="#L6_ComponentRecord">
  <rdfs:subClassOf rdf:resource="base:MaintenanceRecord"/>
</owl:Class>

<!-- L7 ↔ Base RegulatoryRequirement alignment -->
<owl:Class rdf:about="#L7_RegulatoryJurisdiction">
  <rdfs:subClassOf rdf:resource="base:RegulatoryRequirement"/>
</owl:Class>

<!-- Individual alignments: same physical engine across layers -->
<owl:SameIndividual>
  <rdf:Description rdf:about="base:PW119_Engine_Left"/>
  <rdf:Description rdf:about="#L1_Do328_PW119_Left_Instance"/>
</owl:SameIndividual>

<!-- ================================================================ -->
<!-- SWRL-STYLE RULES (expressed as annotation properties)             -->
<!-- Full SWRL execution requires Protégé + SWRLTab plugin            -->
<!-- ================================================================ -->

<owl:AnnotationProperty rdf:about="#swrlRule">
  <rdfs:label xml:lang="en">SWRL Rule</rdfs:label>
  <rdfs:comment xml:lang="en">Annotation encoding a SWRL production rule in human-readable form.</rdfs:comment>
</owl:AnnotationProperty>

<owl:Ontology rdf:about="http://www.semanticweb.org/dell/ontologies/2025/11/CAMP-MOA">
  <swrlRule xml:lang="en">RULE-01 (EGT Threshold Breach → Alert):
    L4_Sensor(?s) ∧ L4_generatesStream(?s,?stream) ∧ L4_currentValue(?stream,?val)
    ∧ L4_alertThreshold(?alert,?thr) ∧ swrlb:greaterThan(?val,?thr)
    → L4_hasAlert(?stream,?alert)</swrlRule>

  <swrlRule xml:lang="en">RULE-02 (Alert + FailureMode → Degraded State):
    L4_MonitoringAlert(?a) ∧ L4_alertIndicates(?a,?fm) ∧ L3_causedByFault(?fm,?fault)
    ∧ base:affectsComponents(?fault,?comp)
    → L3_hasState(?comp, L3_DegradedState)</swrlRule>

  <swrlRule xml:lang="en">RULE-03 (Environmental Stressor Upgrades RPN):
    L7_EnvironmentalStressor(?es) ∧ L7_stressorModifiesFailureMode(?es,?fm)
    ∧ L7_stressorIntensity(?es,"High") ∧ L3_rpnScore(?fm,?rpn)
    ∧ swrlb:multiply(?newRPN,?rpn,1.2)
    → L3_rpnScore(?fm,?newRPN)</swrlRule>

  <swrlRule xml:lang="en">RULE-04 (High RPN → Immediate Work Package):
    L3_FailureMode(?fm) ∧ L3_rpnScore(?fm,?rpn) ∧ swrlb:greaterThan(?rpn,50)
    ∧ L3_mitigatedBy(?fm,?task)
    → L5_groupedInWorkPackage(?task,L5_HeavyWorkPackage)</swrlRule>

  <swrlRule xml:lang="en">RULE-05 (Component near HardTimeLimit → Retirement Event):
    L6_ComponentRecord(?cr) ∧ L6_totalTimeInService_hours(?cr,?tis)
    ∧ L6_hardTimeLimitHours(?cr,?htl) ∧ swrlb:greaterThan(?tis, swrlb:subtract(?htl,500))
    → L6_hasLifecycleEvent(L6_RetirementEvent)</swrlRule>

  <swrlRule xml:lang="en">RULE-06 (AI Engine + Degraded State → Generate Recommendation):
    AI_ReasoningEngine(?eng) ∧ AI_ingestsStream(?eng,?stream)
    ∧ L4_hasAlert(?stream,?alert) ∧ L4_alertIndicates(?alert,?fm)
    ∧ AI_evaluatesAgainst(?eng,?fm)
    → AI_generates(?eng, MaintenanceRecommendation)</swrlRule>
</owl:Ontology>

</rdf:RDF>
