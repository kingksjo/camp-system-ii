</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#L7_subjectToRegulation">
  <rdfs:label xml:lang="en">subjectToRegulation</rdfs:label>
  <rdfs:comment xml:lang="en">Links an aircraft or operation to the regulatory jurisdiction governing it.</rdfs:comment>
  <rdfs:domain rdf:resource="base:Aircraft"/>
  <rdfs:range rdf:resource="#L7_RegulatoryJurisdiction"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#L7_affectedByStressor">
