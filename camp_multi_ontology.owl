<!-- ================================================================ -->
<!-- LAYER 6 — LIFECYCLE ONTOLOGY (Component History)                 -->
<!-- http://www.semanticweb.org/dell/ontologies/2025/11/CAMP-L6-Lifecycle -->
<!-- ================================================================ -->

<owl:Ontology rdf:about="http://www.semanticweb.org/dell/ontologies/2025/11/CAMP-L6-Lifecycle">
  <rdfs:label xml:lang="en">Layer 6 – Lifecycle Ontology</rdfs:label>
  <rdfs:comment xml:lang="en">Tracks the entire service history of components: manufacture, installation, removal, overhaul, and retirement. Enables airworthiness traceability and reliability analysis.</rdfs:comment>
</owl:Ontology>

<!-- Object Properties – L6 -->
<owl:ObjectProperty rdf:about="#L6_hasLifecycleEvent">
  <rdfs:label xml:lang="en">hasLifecycleEvent</rdfs:label>
  <rdfs:comment xml:lang="en">Links a physical entity to events in its service history.</rdfs:comment>
  <rdfs:domain rdf:resource="#L1_PhysicalEntity"/>
  <rdfs:range rdf:resource="#L6_LifecycleEvent"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#L6_precedes">
  <rdfs:label xml:lang="en">precedes</rdfs:label>
  <rdfs:comment xml:lang="en">Temporal ordering of lifecycle events.</rdfs:comment>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
  <rdfs:domain rdf:resource="#L6_LifecycleEvent"/>
  <rdfs:range rdf:resource="#L6_LifecycleEvent"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#L6_hasComponentRecord">
  <rdfs:label xml:lang="en">hasComponentRecord</rdfs:label>
  <rdfs:comment xml:lang="en">Links a component to its authorised release certificate and birth record.</rdfs:comment>
  <rdfs:domain rdf:resource="#L1_PhysicalEntity"/>
  <rdfs:range rdf:resource="#L6_ComponentRecord"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#L6_recordedIn">
  <rdfs:label xml:lang="en">recordedIn</rdfs:label>
  <rdfs:comment xml:lang="en">Links a lifecycle event to the maintenance record (base:MaintenanceRecord) that documents it.</rdfs:comment>
  <rdfs:domain rdf:resource="#L6_LifecycleEvent"/>
  <rdfs:range rdf:resource="base:MaintenanceRecord"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#L6_hasReliabilityMetric">
  <rdfs:label xml:lang="en">hasReliabilityMetric</rdfs:label>
  <rdfs:domain rdf:resource="#L1_PhysicalEntity"/>
  <rdfs:range rdf:resource="#L6_ReliabilityMetric"/>
</owl:ObjectProperty>

<!-- Datatype Properties – L6 -->
<owl:DatatypeProperty rdf:about="#L6_eventDate">
  <rdfs:domain rdf:resource="#L6_LifecycleEvent"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#L6_totalTimeInService_hours">
  <rdfs:label xml:lang="en">totalTimeInService_hours</rdfs:label>
  <rdfs:domain rdf:resource="#L6_ComponentRecord"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#L6_totalCycles">
  <rdfs:domain rdf:resource="#L6_ComponentRecord"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#L6_hardTimeLimitHours">
  <rdfs:label xml:lang="en">hardTimeLimitHours</rdfs:label>
  <rdfs:comment xml:lang="en">Manufacturer life limit for hard-time components.</rdfs:comment>
  <rdfs:domain rdf:resource="#L6_ComponentRecord"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#L6_mtbf_hours">
