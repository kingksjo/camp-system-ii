<!-- ================================================================ -->
<!-- LAYER 4 — MONITORING ONTOLOGY (Sensors & Telemetry)              -->
<!-- http://www.semanticweb.org/dell/ontologies/2025/11/CAMP-L4-Monitoring -->
<!-- ================================================================ -->

<owl:Ontology rdf:about="http://www.semanticweb.org/dell/ontologies/2025/11/CAMP-L4-Monitoring">
  <rdfs:label xml:lang="en">Layer 4 – Monitoring Ontology</rdfs:label>
  <rdfs:comment xml:lang="en">Models the sensor network, telemetry streams, ACARS/ACMS data, alert thresholds, and real-time health indicators.</rdfs:comment>
</owl:Ontology>

<!-- Object Properties – L4 -->
<owl:ObjectProperty rdf:about="#L4_hasSensor">
  <rdfs:label xml:lang="en">hasSensor</rdfs:label>
  <rdfs:comment xml:lang="en">Links a monitored physical entity (L1) to its associated sensor.</rdfs:comment>
  <rdfs:domain rdf:resource="#L1_PhysicalEntity"/>
  <rdfs:range rdf:resource="#L4_Sensor"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#L4_generatesStream">
  <rdfs:label xml:lang="en">generatesStream</rdfs:label>
  <rdfs:comment xml:lang="en">A sensor generates one or more telemetry data streams.</rdfs:comment>
  <rdfs:domain rdf:resource="#L4_Sensor"/>
  <rdfs:range rdf:resource="#L4_TelemetryStream"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#L4_hasAlert">
  <rdfs:label xml:lang="en">hasAlert</rdfs:label>
  <rdfs:comment xml:lang="en">A telemetry stream triggers an alert when a threshold is breached.</rdfs:comment>
  <rdfs:domain rdf:resource="#L4_TelemetryStream"/>
  <rdfs:range rdf:resource="#L4_MonitoringAlert"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#L4_alertIndicates">
  <rdfs:label xml:lang="en">alertIndicates</rdfs:label>
  <rdfs:comment xml:lang="en">Links a monitoring alert to the behavioral failure mode it signals (L3 cross-link).</rdfs:comment>
  <rdfs:domain rdf:resource="#L4_MonitoringAlert"/>
  <rdfs:range rdf:resource="#L3_FailureMode"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#L4_forwardsTo">
  <rdfs:label xml:lang="en">forwardsTo</rdfs:label>
  <rdfs:comment xml:lang="en">Telemetry stream forwarded to a ground system or AI reasoning engine.</rdfs:comment>
  <rdfs:domain rdf:resource="#L4_TelemetryStream"/>
  <rdfs:range rdf:resource="#L4_GroundSystem"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#L4_bridgesBaseSensorData">
  <rdfs:label xml:lang="en">bridgesBaseSensorData</rdfs:label>
  <rdfs:comment xml:lang="en">Alignment link: L4 Sensor corresponds to a base SensorData individual.</rdfs:comment>
  <rdfs:domain rdf:resource="#L4_Sensor"/>
  <rdfs:range rdf:resource="base:SensorData"/>
</owl:ObjectProperty>

<!-- Datatype Properties – L4 -->
<owl:DatatypeProperty rdf:about="#L4_samplingRateHz">
  <rdfs:label xml:lang="en">samplingRateHz</rdfs:label>
  <rdfs:domain rdf:resource="#L4_Sensor"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#L4_alertThreshold">
  <rdfs:label xml:lang="en">alertThreshold</rdfs:label>
  <rdfs:domain rdf:resource="#L4_MonitoringAlert"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#L4_alertLevel">
  <rdfs:label xml:lang="en">alertLevel</rdfs:label>
  <rdfs:comment xml:lang="en">Warning, Caution, or Advisory.</rdfs:comment>
  <rdfs:domain rdf:resource="#L4_MonitoringAlert"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#L4_currentValue">
  <rdfs:label xml:lang="en">currentValue</rdfs:label>
  <rdfs:domain rdf:resource="#L4_TelemetryStream"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#L4_timestamp">
  <rdfs:label xml:lang="en">timestamp</rdfs:label>
  <rdfs:domain rdf:resource="#L4_TelemetryStream"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
</owl:DatatypeProperty>

<!-- Classes – L4 -->
<owl:Class rdf:about="#L4_Sensor">
  <rdfs:label xml:lang="en">Sensor</rdfs:label>
  <rdfs:comment xml:lang="en">A physical transducer that measures a parameter on the aircraft.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#L4_TemperatureSensor">
  <rdfs:subClassOf rdf:resource="#L4_Sensor"/>
  <rdfs:label xml:lang="en">TemperatureSensor</rdfs:label>
</owl:Class>

<owl:Class rdf:about="#L4_PressureSensor">
  <rdfs:subClassOf rdf:resource="#L4_Sensor"/>
  <rdfs:label xml:lang="en">PressureSensor</rdfs:label>
</owl:Class>

<owl:Class rdf:about="#L4_VibrationSensor">
  <rdfs:subClassOf rdf:resource="#L4_Sensor"/>
  <rdfs:label xml:lang="en">VibrationSensor</rdfs:label>
</owl:Class>

<owl:Class rdf:about="#L4_FuelQuantitySensor">
  <rdfs:subClassOf rdf:resource="#L4_Sensor"/>
  <rdfs:label xml:lang="en">FuelQuantitySensor</rdfs:label>
</owl:Class>

<owl:Class rdf:about="#L4_StrainGaugeSensor">
  <rdfs:subClassOf rdf:resource="#L4_Sensor"/>
  <rdfs:label xml:lang="en">StrainGaugeSensor</rdfs:label>
</owl:Class>

<owl:Class rdf:about="#L4_TelemetryStream">
  <rdfs:label xml:lang="en">TelemetryStream</rdfs:label>
  <rdfs:comment xml:lang="en">A time-series data stream produced by a sensor (ACARS, ACMS, QAR, FDR).</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#L4_ACARSStream">
  <rdfs:subClassOf rdf:resource="#L4_TelemetryStream"/>
  <rdfs:label xml:lang="en">ACARSStream</rdfs:label>
</owl:Class>

<owl:Class rdf:about="#L4_QARStream">
  <rdfs:subClassOf rdf:resource="#L4_TelemetryStream"/>
  <rdfs:label xml:lang="en">QARStream (Quick Access Recorder)</rdfs:label>
</owl:Class>

<owl:Class rdf:about="#L4_MonitoringAlert">
  <rdfs:label xml:lang="en">MonitoringAlert</rdfs:label>
  <rdfs:comment xml:lang="en">An automated alert generated when a telemetry parameter exceeds its threshold.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#L4_GroundSystem">
  <rdfs:label xml:lang="en">GroundSystem</rdfs:label>
  <rdfs:comment xml:lang="en">Ground-side system receiving and processing aircraft telemetry (e.g. AMOS, AIRMAN, AI engine).</rdfs:comment>
</owl:Class>

