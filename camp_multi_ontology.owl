<!-- LAYER 7 — ENVIRONMENTAL ONTOLOGY (Operating Context)             -->
<!-- http://www.semanticweb.org/dell/ontologies/2025/11/CAMP-L7-Environmental -->
<!-- ================================================================ -->

<owl:Ontology rdf:about="http://www.semanticweb.org/dell/ontologies/2025/11/CAMP-L7-Environmental">
  <rdfs:label xml:lang="en">Layer 7 – Environmental Ontology</rdfs:label>
  <rdfs:comment xml:lang="en">Captures the operational environment: meteorological conditions, route profiles, regulatory jurisdiction, and environmental stressors affecting component degradation rates.</rdfs:comment>
</owl:Ontology>

<!-- Object Properties – L7 -->
<owl:ObjectProperty rdf:about="#L7_operatesInEnvironment">
  <rdfs:label xml:lang="en">operatesInEnvironment</rdfs:label>
  <rdfs:domain rdf:resource="#L1_PhysicalEntity"/>
  <rdfs:range rdf:resource="#L7_OperatingEnvironment"/>
</owl:ObjectProperty>

